# Set platform to 12.0 to resolve Reachability/Pusher version conflicts
platform :ios, '12.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = '1'

project 'Runner', {
  'Debug' => :debug,
  'Release' => :release,
  'Profile' => :profile,
}

# Helper to find podhelper.rb
def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  if File.exist?(generated_xcode_build_settings_path)
    File.foreach(generated_xcode_build_settings_path) do |line|
      matches = line.match(/\A([A-Z_]+)=(.*)\Z/)
      next unless matches
      return matches[2] if matches[1] == 'FLUTTER_ROOT'
    end
  end
  ENV['FLUTTER_ROOT']
end

podhelper_path = File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb')
if File.exist?(podhelper_path)
  load podhelper_path
else
  # Fallback to local path if SDK path fails
  load File.expand_path(File.join('..', 'Flutter', 'podhelper.rb'), __FILE__)
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  install_all_flutter_pods(File.dirname(File.realpath(__FILE__)))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '12.0'
      # Fix for Reachability and other pods that might have higher requirements
      config.build_settings['SWIFT_VERSION'] = '5.0'
    end
  end
end
